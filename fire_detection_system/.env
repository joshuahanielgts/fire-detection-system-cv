# AI Fire Detection System - Environment Configuration

# Flask Secret Key (generate a random string)
FLASK_SECRET_KEY=fire-detection-super-secret-key-2024

# Google OAuth Client ID (optional - leave empty to use dev mode)
GOOGLE_CLIENT_ID=

# Detection Settings
CONFIDENCE_THRESHOLD=0.6

# Development Mode (set to 'true' to bypass Google login)
DEV_MODE=true

